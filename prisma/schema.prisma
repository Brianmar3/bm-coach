generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model StudentRecord {
  id                  String                      @id
  phoneNormalized     String?                     @unique
  primaryScheduleId   String?
  data                Json
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  payments            StudentPayment[]
  physicalEvaluations PhysicalEvaluation[]
  routineAssignments  TrainingRoutineAssignment[]
  weeklyClasses       WeeklyClassAssignment[]
  attendances         ClassAttendance[]
  primarySchedule     WeeklyClassSchedule?        @relation("StudentPrimarySchedule", fields: [primaryScheduleId], references: [id], onDelete: SetNull)
  portalCredential    StudentPortalCredential?
  workoutSessions     WorkoutSession[]
  followUpComments    FollowUpComment[]
  classResponses      ClassOccurrenceAttendance[]
  classWorkoutLogs    ClassWorkoutLog[]

  @@index([primaryScheduleId])
  @@map("students")
}

model StudentPortalCredential {
  studentId           String                 @id
  username            String                 @unique
  passwordHash        String
  active              Boolean                @default(true)
  mustChangePassword  Boolean                @default(true)
  failedLoginAttempts Int                    @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  student             StudentRecord          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sessions            StudentPortalSession[]

  @@map("student_portal_credentials")
}

model StudentPortalSession {
  id         String                  @id @default(cuid())
  studentId  String
  tokenHash  String                  @unique
  expiresAt  DateTime
  createdAt  DateTime                @default(now())
  lastUsedAt DateTime                @default(now())
  credential StudentPortalCredential @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@index([studentId])
  @@index([expiresAt])
  @@map("student_portal_sessions")
}

enum StudentPaymentStatus {
  PAGADO
  PENDIENTE
  VENCIDO
  PROXIMO_A_VENCER
}

model StudentPayment {
  id        String               @id @default(cuid())
  studentId String
  amount    Decimal              @db.Decimal(12, 2)
  concept   String
  dueDate   DateTime
  paidDate  DateTime?
  method    String
  status    StudentPaymentStatus @default(PENDIENTE)
  notes     String               @default("")
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  student   StudentRecord        @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([status, dueDate])
  @@map("student_payments")
}

model PaymentRecord {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

model EventRecord {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("events")
}

enum CoachEventType {
  EVALUACION
  REUNION
  COMPETENCIA
  RECORDATORIO
}

enum CoachEventStatus {
  PENDIENTE
  COMPLETADO
}

model CoachEvent {
  id          String           @id @default(cuid())
  title       String
  description String           @default("")
  date        DateTime
  time        String
  color       String           @default("#facc15")
  type        CoachEventType
  status      CoachEventStatus @default(PENDIENTE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([date, time])
  @@index([status])
  @@map("coach_events")
}

model RoutineRecord {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("routines")
}

enum TrainingRoutineLevel {
  PRINCIPIANTE
  INTERMEDIO
  AVANZADO
}

enum TrainingRoutineStatus {
  ACTIVA
  ARCHIVADA
}

enum TrainingEffortType {
  RPE
  RIR
}

model TrainingRoutine {
  id              String                      @id @default(cuid())
  name            String
  objective       String
  level           TrainingRoutineLevel
  status          TrainingRoutineStatus       @default(ACTIVA)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  archivedAt      DateTime?
  days            TrainingRoutineDay[]
  assignments     TrainingRoutineAssignment[]
  workoutSessions WorkoutSession[]
  versions        TrainingRoutineVersion[]

  @@index([objective])
  @@index([status])
  @@map("training_routines")
}

model TrainingRoutineVersion {
  id          String          @id @default(cuid())
  routineId   String
  version     Int
  summary     String
  fingerprint String
  snapshot    Json
  createdAt   DateTime        @default(now())
  routine     TrainingRoutine @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@unique([routineId, version])
  @@index([routineId, createdAt])
  @@map("training_routine_versions")
}

model TrainingRoutineDay {
  id              String                    @id @default(cuid())
  routineId       String
  dayNumber       Int
  routine         TrainingRoutine           @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercises       TrainingRoutineExercise[]
  workoutSessions WorkoutSession[]
  active          Boolean                   @default(true)
  archivedAt      DateTime?

  @@unique([routineId, dayNumber])
  @@index([routineId, active])
  @@map("training_routine_days")
}

model TrainingRoutineExercise {
  id               String               @id @default(cuid())
  dayId            String
  name             String
  muscleGroup      String
  sets             Int
  repetitions      String
  weight           Decimal?             @db.Decimal(7, 2)
  effortType       TrainingEffortType
  effortValue      Decimal?             @db.Decimal(4, 1)
  restSeconds      Int?
  observations     String               @default("")
  videoUrl         String?
  order            Int
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  day              TrainingRoutineDay   @relation(fields: [dayId], references: [id], onDelete: Cascade)
  workoutLogs      WorkoutExerciseLog[]
  followUpComments FollowUpComment[]
  active           Boolean              @default(true)
  archivedAt       DateTime?

  @@index([dayId, order])
  @@index([dayId, active])
  @@map("training_routine_exercises")
}

model TrainingRoutineAssignment {
  routineId  String
  studentId  String
  assignedAt DateTime        @default(now())
  active     Boolean         @default(true)
  archivedAt DateTime?
  routine    TrainingRoutine @relation(fields: [routineId], references: [id], onDelete: Cascade)
  student    StudentRecord   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([routineId, studentId])
  @@index([studentId])
  @@index([studentId, active])
  @@map("training_routine_assignments")
}

model EvaluationRecord {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("evaluations")
}

model PhysicalEvaluation {
  id                String            @id @default(cuid())
  studentId         String
  date              DateTime
  weight            Decimal?          @db.Decimal(7, 2)
  height            Decimal?          @db.Decimal(5, 2)
  bodyFatPercentage Decimal?          @db.Decimal(5, 2)
  muscleMass        Decimal?          @db.Decimal(7, 2)
  visceralFat       Decimal?          @db.Decimal(5, 2)
  waist             Decimal?          @db.Decimal(7, 2)
  hip               Decimal?          @db.Decimal(7, 2)
  chest             Decimal?          @db.Decimal(7, 2)
  rightArm          Decimal?          @db.Decimal(7, 2)
  leftArm           Decimal?          @db.Decimal(7, 2)
  rightThigh        Decimal?          @db.Decimal(7, 2)
  leftThigh         Decimal?          @db.Decimal(7, 2)
  rightCalf         Decimal?          @db.Decimal(7, 2)
  leftCalf          Decimal?          @db.Decimal(7, 2)
  notes             String            @default("")
  frontPhotoUrl     String?
  sidePhotoUrl      String?
  backPhotoUrl      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  student           StudentRecord     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  followUpComments  FollowUpComment[]

  @@index([studentId, date])
  @@map("physical_evaluations")
}

enum WorkoutSessionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model WorkoutSession {
  id                       String               @id @default(cuid())
  studentId                String
  routineId                String?
  dayId                    String?
  routineNameSnapshot      String
  routineDayNumberSnapshot Int
  date                     DateTime             @db.Date
  startTime                String
  durationMinutes          Int?
  energyBefore             Int?
  difficulty               Int?
  energyAfter              Int?
  finalComment             String               @default("")
  hasPain                  Boolean              @default(false)
  painDetails              String               @default("")
  status                   WorkoutSessionStatus @default(PENDING)
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  student                  StudentRecord        @relation(fields: [studentId], references: [id], onDelete: Restrict)
  routine                  TrainingRoutine?     @relation(fields: [routineId], references: [id], onDelete: SetNull)
  day                      TrainingRoutineDay?  @relation(fields: [dayId], references: [id], onDelete: SetNull)
  exercises                WorkoutExerciseLog[]
  comments                 FollowUpComment[]

  @@index([studentId, date])
  @@index([status, updatedAt])
  @@map("workout_sessions")
}

model WorkoutExerciseLog {
  id                  String                   @id @default(cuid())
  sessionId           String
  exerciseId          String?
  exerciseReferenceId String
  observation         String                   @default("")
  snapshotVersion     Int?
  exerciseName        String?
  targetSets          Int?
  targetRepetitions   String?
  suggestedWeight     Decimal?                 @db.Decimal(7, 2)
  targetEffortType    TrainingEffortType?
  targetEffortValue   Decimal?                 @db.Decimal(4, 1)
  targetRestSeconds   Int?
  coachInstructions   String?
  exerciseOrder       Int?
  routineName         String?
  routineDayNumber    Int?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  session             WorkoutSession           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise            TrainingRoutineExercise? @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  sets                WorkoutSetLog[]

  @@unique([sessionId, exerciseId])
  @@index([exerciseId, updatedAt])
  @@index([exerciseReferenceId, updatedAt])
  @@map("workout_exercise_logs")
}

model WorkoutSetLog {
  id            String             @id @default(cuid())
  exerciseLogId String
  setNumber     Int
  weight        Decimal?           @db.Decimal(7, 2)
  repetitions   Int?
  effort        Decimal?           @db.Decimal(4, 1)
  completed     Boolean            @default(false)
  observation   String             @default("")
  exerciseLog   WorkoutExerciseLog @relation(fields: [exerciseLogId], references: [id], onDelete: Cascade)

  @@unique([exerciseLogId, setNumber])
  @@map("workout_set_logs")
}

enum FollowUpAuthor {
  STUDENT
  COACH
}

enum FollowUpContext {
  SESSION
  EXERCISE
  EVALUATION
  GENERAL
}

enum FollowUpCategory {
  QUESTION
  DIFFICULTY
  PAIN
  FEEDBACK
}

enum FollowUpStatus {
  PENDING
  REVIEWED
}

model FollowUpComment {
  id           String                   @id @default(cuid())
  studentId    String
  author       FollowUpAuthor
  context      FollowUpContext
  category     FollowUpCategory
  status       FollowUpStatus           @default(PENDING)
  body         String
  private      Boolean                  @default(false)
  sessionId    String?
  exerciseId   String?
  evaluationId String?
  parentId     String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  student      StudentRecord            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session      WorkoutSession?          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise     TrainingRoutineExercise? @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  evaluation   PhysicalEvaluation?      @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  parent       FollowUpComment?         @relation("FollowUpReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      FollowUpComment[]        @relation("FollowUpReplies")

  @@index([studentId, createdAt])
  @@index([status, category])
  @@index([parentId])
  @@map("follow_up_comments")
}

model CoachSettingsRecord {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coach_settings")
}

enum ClassWeekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}

model WeeklyClassSchedule {
  id              String                  @id @default(cuid())
  dayOfWeek       ClassWeekday
  startTime       String
  endTime         String
  classType       String
  capacity        Int?
  active          Boolean                 @default(true)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  assignments     WeeklyClassAssignment[]
  attendances     ClassAttendance[]
  primaryStudents StudentRecord[]         @relation("StudentPrimarySchedule")
  occurrences     ClassOccurrence[]

  @@index([dayOfWeek, startTime])
  @@index([active])
  @@map("weekly_class_schedules")
}

enum ClassOccurrenceStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum ClassResponseStatus {
  GOING
  NOT_GOING
}

enum ClassActualAttendance {
  UNKNOWN
  PRESENT
  ABSENT
  CANCELLED
}

enum ClassWorkoutLogStatus {
  DRAFT
  COMPLETED
}

model ClassOccurrence {
  id                String                      @id @default(cuid())
  scheduleId        String?
  date              DateTime                    @db.Date
  startTime         String
  endTime           String
  classNameSnapshot String
  categorySnapshot  String
  status            ClassOccurrenceStatus       @default(SCHEDULED)
  capacityOverride  Int?
  internalNotes     String                      @default("")
  strengthEnabled   Boolean                     @default(false)
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  schedule          WeeklyClassSchedule?        @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  responses         ClassOccurrenceAttendance[]
  strengthBlock     ClassStrengthBlock?
  workoutLogs       ClassWorkoutLog[]

  @@unique([scheduleId, date])
  @@index([date, startTime])
  @@index([status, date])
  @@map("class_occurrences")
}

model ClassOccurrenceAttendance {
  id               String                @id @default(cuid())
  occurrenceId     String
  studentId        String
  response         ClassResponseStatus?
  actualAttendance ClassActualAttendance @default(UNKNOWN)
  respondedAt      DateTime?
  checkedInAt      DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  occurrence       ClassOccurrence       @relation(fields: [occurrenceId], references: [id], onDelete: Restrict)
  student          StudentRecord         @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@unique([occurrenceId, studentId])
  @@index([studentId, updatedAt])
  @@index([occurrenceId, response])
  @@map("class_occurrence_attendances")
}

model ClassStrengthBlock {
  id           String                  @id @default(cuid())
  occurrenceId String                  @unique
  name         String
  notes        String                  @default("")
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  occurrence   ClassOccurrence         @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  exercises    ClassStrengthExercise[]

  @@map("class_strength_blocks")
}

model ClassStrengthExercise {
  id              String             @id @default(cuid())
  strengthBlockId String
  exerciseName    String
  order           Int
  suggestedSets   Int
  suggestedReps   String
  instructions    String             @default("")
  strengthBlock   ClassStrengthBlock @relation(fields: [strengthBlockId], references: [id], onDelete: Cascade)

  @@unique([strengthBlockId, order])
  @@map("class_strength_exercises")
}

model ClassWorkoutLog {
  id                String                @id @default(cuid())
  occurrenceId      String
  studentId         String
  classNameSnapshot String
  classDateSnapshot DateTime              @db.Date
  status            ClassWorkoutLogStatus @default(DRAFT)
  notes             String                @default("")
  completedAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  occurrence        ClassOccurrence       @relation(fields: [occurrenceId], references: [id], onDelete: Restrict)
  student           StudentRecord         @relation(fields: [studentId], references: [id], onDelete: Restrict)
  exercises         ClassExerciseLog[]

  @@unique([occurrenceId, studentId])
  @@index([studentId, classDateSnapshot])
  @@map("class_workout_logs")
}

model ClassExerciseLog {
  id                   String          @id @default(cuid())
  classWorkoutLogId    String
  exerciseNameSnapshot String
  order                Int
  notes                String          @default("")
  workoutLog           ClassWorkoutLog @relation(fields: [classWorkoutLogId], references: [id], onDelete: Cascade)
  sets                 ClassSetLog[]

  @@unique([classWorkoutLogId, order])
  @@map("class_exercise_logs")
}

model ClassSetLog {
  id                 String           @id @default(cuid())
  classExerciseLogId String
  setNumber          Int
  weight             Decimal?         @db.Decimal(7, 2)
  repetitions        Int?
  unit               String           @default("kg")
  notes              String           @default("")
  exerciseLog        ClassExerciseLog @relation(fields: [classExerciseLogId], references: [id], onDelete: Cascade)

  @@unique([classExerciseLogId, setNumber])
  @@map("class_set_logs")
}

model WeeklyClassAssignment {
  scheduleId String
  studentId  String
  assignedAt DateTime            @default(now())
  schedule   WeeklyClassSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  student    StudentRecord       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([scheduleId, studentId])
  @@index([studentId])
  @@map("weekly_class_assignments")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  JUSTIFIED
}

model ClassAttendance {
  id                String               @id @default(cuid())
  scheduleId        String?
  studentId         String
  date              DateTime             @db.Date
  status            AttendanceStatus
  scheduleLabel     String
  scheduleStartTime String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  schedule          WeeklyClassSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  student           StudentRecord        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, studentId, date])
  @@index([date])
  @@index([studentId, date])
  @@index([status, date])
  @@map("class_attendances")
}

model ClassSession {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  startTime   String
  endTime     String
  location    String
  capacity    Int
  status      String   @default("programada")
  description String   @default("")
  students    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("classes")
}
