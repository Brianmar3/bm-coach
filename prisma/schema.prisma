generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model StudentRecord {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  payments  StudentPayment[]

  @@map("students")
}

enum StudentPaymentStatus {
  PAGADO
  PENDIENTE
  VENCIDO
  PROXIMO_A_VENCER
}

model StudentPayment {
  id          String               @id @default(cuid())
  studentId   String
  amount      Decimal              @db.Decimal(12, 2)
  concept     String
  dueDate     DateTime
  paidDate    DateTime?
  method      String
  status      StudentPaymentStatus @default(PENDIENTE)
  notes       String               @default("")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  student     StudentRecord        @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([status, dueDate])
  @@map("student_payments")
}

model PaymentRecord {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

model EventRecord {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("events")
}

enum CoachEventType {
  EVALUACION
  REUNION
  COMPETENCIA
  RECORDATORIO
}

enum CoachEventStatus {
  PENDIENTE
  COMPLETADO
}

model CoachEvent {
  id          String           @id @default(cuid())
  title       String
  description String           @default("")
  date        DateTime
  time        String
  color       String           @default("#facc15")
  type        CoachEventType
  status      CoachEventStatus @default(PENDIENTE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([date, time])
  @@index([status])
  @@map("coach_events")
}

model RoutineRecord {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("routines")
}

model EvaluationRecord {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("evaluations")
}

model CoachSettingsRecord {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coach_settings")
}

model ClassSession {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  startTime   String
  endTime     String
  location    String
  capacity    Int
  status      String   @default("programada")
  description String   @default("")
  students    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("classes")
}
